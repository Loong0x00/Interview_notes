{
  "name": "interview-analysis-report",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently -n server,vite -c blue,green \"npm run server\" \"npm run dev\"",
